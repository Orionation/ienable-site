---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description: string;
    tags: string[];
    readTime: string;
    emoji?: string;
    author?: string;
  };
}

const { frontmatter } = Astro.props;
const { title, date, description, tags, readTime, emoji, author = 'iEnable Team' } = frontmatter;
---

<Base 
  title={`${title} — iEnable Blog`} 
  description={description}
  canonical={`https://ienable.ai/blog/${Astro.params.slug}.html`}
>
  <style>
    .post-hero {
      padding: 140px 24px 60px;
      text-align: center;
      background: radial-gradient(ellipse at 50% 0%, rgba(99, 102, 241, 0.08), transparent 60%), var(--dark);
      position: relative;
    }
    
    .post-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: 
        linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
    }
    
    .post-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      font-size: 13px;
      color: var(--dark-muted);
      font-weight: 500;
      margin-bottom: 20px;
      position: relative;
    }
    
    .post-tag {
      padding: 4px 10px;
      background: rgba(34, 197, 94, 0.12);
      color: var(--green);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .post-hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 52px;
      font-weight: 400;
      color: white;
      max-width: 700px;
      margin: 0 auto 16px;
      line-height: 1.15;
      position: relative;
    }
    
    .post-hero h1 em {
      font-style: italic;
      color: var(--brown);
    }
    
    .post-hero .subtitle {
      font-size: 18px;
      color: var(--dark-muted);
      max-width: 540px;
      margin: 0 auto;
      line-height: 1.7;
      position: relative;
    }
    
    article {
      max-width: 680px;
      margin: 0 auto;
      padding: 60px 24px 100px;
    }
    
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--dark-muted);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      margin-bottom: 20px;
    }
    
    .back-link:hover {
      color: white;
    }
    
    article :global(h2) {
      font-family: 'DM Serif Display', serif;
      font-size: 32px;
      font-weight: 400;
      color: white;
      margin: 48px 0 16px;
      line-height: 1.25;
    }
    
    article :global(h3) {
      font-size: 24px;
      font-weight: 700;
      color: white;
      margin: 36px 0 12px;
    }
    
    article :global(p) {
      font-size: 16px;
      line-height: 1.8;
      color: var(--dark-muted);
      margin-bottom: 20px;
    }
    
    article :global(strong) {
      color: var(--dark-text);
      font-weight: 600;
    }
    
    article :global(em) {
      font-style: italic;
    }
    
    article :global(blockquote) {
      border-left: 3px solid var(--green);
      padding: 16px 24px;
      margin: 28px 0;
      background: rgba(34, 197, 94, 0.05);
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    
    article :global(blockquote p) {
      margin: 0;
      color: var(--dark-text);
      font-style: italic;
    }
    
    article :global(ul), article :global(ol) {
      margin: 0 0 20px 20px;
      color: var(--dark-muted);
      line-height: 2;
    }
    
    article :global(li) {
      font-size: 16px;
    }
    
    article :global(code) {
      background: var(--dark-card);
      padding: 2px 6px;
      border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      color: var(--cyan);
    }
    
    article :global(pre) {
      background: var(--dark-card);
      border: 1px solid var(--dark-border);
      border-radius: var(--radius);
      padding: 20px;
      overflow-x: auto;
      margin: 28px 0;
    }
    
    article :global(pre code) {
      background: none;
      padding: 0;
      color: var(--dark-text);
    }
    
    article :global(a) {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid rgba(99, 102, 241, 0.3);
      transition: all 0.2s;
    }
    
    article :global(a:hover) {
      color: var(--cyan);
      border-bottom-color: var(--cyan);
    }
    
    @media (max-width: 600px) {
      .post-hero h1 {
        font-size: 36px;
      }
      
      article :global(h2) {
        font-size: 26px;
      }
    }
  </style>
  
  <section class="post-hero">
    <div class="post-meta">
      {emoji && <span class="post-tag">{emoji}</span>}
      <span class="post-tag">{tags[0]}</span>
      <span>{new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
      <span>·</span>
      <span>{author}</span>
      <span>·</span>
      <span>{readTime}</span>
    </div>
    <h1 set:html={title}></h1>
    {description && <p class="subtitle">{description}</p>}
  </section>
  
  <article>
    <a href="/blog/" class="back-link">← Back to Blog</a>
    <slot />
  </article>
</Base>
