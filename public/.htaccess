<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(www\.)?ienable\.ai$ [NC]
RewriteRule ^(.*)$ https://ienable.ai/$1 [L,R=301]

# 301 Redirects: Fix broken pillar page URLs
RewriteRule ^blog/what-is-ai-enablement\.html$ /blog/what-is-ai-enablement-guide.html [R=301,L]
RewriteRule ^blog/context-engineering-as-organizational-discipline\.html$ /blog/context-engineering-enterprise-guide.html [R=301,L]

# Fix trailing-slash 500 errors: redirect to non-slash version
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)/$ /blog/$1 [R=301,L]

# Serve .html files for clean URLs (Astro static build)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</IfModule>
